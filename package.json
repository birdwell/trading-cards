{
  "name": "trading-cards",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "start": "node scripts/setup-db.js && concurrently \"BACKEND_PORT=3002 pnpm run server\" \"PORT=${PORT:-3000} pnpm run client:start\"",
    "dev": "concurrently \"pnpm run server:dev\" \"pnpm run client:dev\"",
    "server": "tsx server/api/server.ts",
    "server:dev": "tsx --watch server/api/server.ts",
    "client:dev": "pnpm --filter client dev",
    "client:build": "pnpm --filter client build",
    "client:start": "pnpm --filter client start",
    "build": "concurrently --kill-others-on-fail -n client,server -c auto \"pnpm run client:build\" \"pnpm run typecheck\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "db:setup": "node scripts/setup-db.js",
    "db:migrate-sqlite": "tsx scripts/migrate-sqlite-to-postgres.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.12",
    "@clerk/backend": "^3.11.7",
    "@trpc/client": "11.7.2",
    "@trpc/server": "11.7.2",
    "@types/axios": "^0.9.36",
    "@types/node": "^24.3.1",
    "ai": "^5.0.34",
    "axios": "^1.11.0",
    "concurrently": "^9.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.44.5",
    "exceljs": "^4.4.0",
    "pg": "^8.22.0",
    "pino": "^9.9.4",
    "pino-pretty": "^13.1.1",
    "playwright": "^1.55.0",
    "ts-node": "^10.9.2",
    "tsx": "4.21.0",
    "typescript": "^5.9.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.4",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "0.31.8",
    "jest": "30.2.0",
    "ts-jest": "29.4.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
