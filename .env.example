# Database Configuration
DATABASE_URL=file:./database.db

# Server Configuration
NODE_ENV=development

# Gemini Configuration
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Port Configuration
BACKEND_PORT=3002
FRONTEND_PORT=3000

