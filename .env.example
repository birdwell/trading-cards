# Database Configuration (Railway Postgres)
# Local/dev: use Postgres DATABASE_PUBLIC_URL from Railway
# Deployed app service: DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:password@host:port/railway

# Server Configuration
NODE_ENV=development

# Gemini Configuration
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Port Configuration
BACKEND_PORT=3002
FRONTEND_PORT=3000
NEXT_PUBLIC_BACKEND_PORT=3002

# Clerk Authentication
# Create an app at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
